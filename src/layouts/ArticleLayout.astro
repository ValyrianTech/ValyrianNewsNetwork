---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  categories: string[];
  tags: string[];
  meta_description: string;
  read_time_minutes: number;
  featured_image?: string;
  featured_image_caption?: string;
}

const { 
  title, 
  date, 
  categories, 
  tags, 
  meta_description, 
  read_time_minutes,
  featured_image,
  featured_image_caption
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={title} description={meta_description}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-10 animate-fade-in-up">
      <div class="flex flex-wrap gap-3 mb-5">
        {categories.map(category => (
          <a 
            href={`/categories/${category.toLowerCase().replace(/[\s/]+/g, '-')}`}
            class="category-pill no-underline hover:underline"
          >
            {category}
          </a>
        ))}
      </div>
      
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-black mb-5 leading-[1.1] tracking-tight text-vnn-ink">
        {title}
      </h1>
      
      <div class="flex flex-wrap items-center gap-3 edition-date">
        <span class="font-semibold text-vnn-ink" style="font-size: 0.75rem;">Valyrian News Network</span>
        <span class="text-vnn-rule">—</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-vnn-rule">—</span>
        <span>{read_time_minutes} min read</span>
      </div>
    </header>
    
    {featured_image && (
      <figure class="mb-10 animate-fade-in-up stagger-1">
        <img 
          src={featured_image} 
          alt={featured_image_caption || title}
          class="w-full"
        />
        {featured_image_caption && (
          <figcaption class="text-sm text-vnn-muted mt-3 text-center font-mono" style="font-size: 0.75rem;">
            {featured_image_caption}
          </figcaption>
        )}
      </figure>
    )}
    
    <div class="article-content animate-fade-in-up stagger-2">
      <slot />
    </div>
    
    <footer class="mt-14 pt-10 hairline-top">
      {tags.length > 0 && (
        <div class="mb-8">
          <h4 class="font-mono text-xs uppercase tracking-[0.15em] text-vnn-muted mb-4">Tags</h4>
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <a 
                href={`/tags/${tag.toLowerCase().replace(/[\s/]+/g, '-')}`}
                class="px-3 py-1.5 bg-vnn-light text-vnn-gray text-xs font-mono no-underline hover:bg-vnn-rule hover:text-vnn-ink transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>
      )}
      
      <div class="bg-vnn-paper border border-vnn-rule p-5 text-sm text-vnn-gray">
        <p class="m-0">
          <strong class="text-vnn-ink">Methodology Note:</strong> This article was synthesized and written by AI systems from Valyrian Tech. 
          Our process ensures factual sourcing and contextual analysis. 
          <a href="/about" class="text-vnn-vermillion no-underline hover:underline">Learn more about how VNN works</a>.
        </p>
      </div>
    </footer>
  </article>
</BaseLayout>
