---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCountries } from '../utils/countries';
import { withBase } from '../utils/urls';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const dayKey = (d: Date) => Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
const sortedPosts = allPosts.sort((a, b) => {
  const dayDiff = dayKey(b.data.date) - dayKey(a.data.date);
  if (dayDiff !== 0) return dayDiff;
  return a.data.date.valueOf() - b.data.date.valueOf();
});

const featuredPost = sortedPosts[0];
const secondaryPosts = sortedPosts.slice(1, 3);
const remainingPosts = sortedPosts.slice(3);

// Build country counts from all posts
const countryCounts: Record<string, number> = {};
for (const post of sortedPosts) {
  for (const country of getCountries(post.data.tags)) {
    countryCounts[country] = (countryCounts[country] || 0) + 1;
  }
}
const activeCountries = Object.entries(countryCounts)
  .sort((a, b) => a[0].localeCompare(b[0]));

// Date helpers
function formatDateISO(date: Date): string {
  return date.toISOString().split('T')[0];
}

// Build set of dates that have articles (ISO strings) + counts — passed to JS as JSON
const articleDateCounts: Record<string, number> = {};
for (const post of sortedPosts) {
  const key = formatDateISO(post.data.date);
  articleDateCounts[key] = (articleDateCounts[key] || 0) + 1;
}

// Group ALL posts by date (used when date filter is active and hero is hidden)
const allGroupedByDate = sortedPosts.reduce((groups: Record<string, typeof sortedPosts>, post) => {
  const dateKey = post.data.date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC'
  });
  if (!groups[dateKey]) {
    groups[dateKey] = [];
  }
  groups[dateKey].push(post);
  return groups;
}, {});

// Group remaining posts (excluding hero) for the default view
const remainingGroupedByDate = remainingPosts.reduce((groups: Record<string, typeof remainingPosts>, post) => {
  const dateKey = post.data.date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC'
  });
  if (!groups[dateKey]) {
    groups[dateKey] = [];
  }
  groups[dateKey].push(post);
  return groups;
}, {});

const allDateGroups = Object.entries(allGroupedByDate);
const remainingDateGroups = Object.entries(remainingGroupedByDate);
---

<BaseLayout title="Home">
  <div class="paper-texture">
    {sortedPosts.length === 0 ? (
      <div class="text-center py-24 max-w-xl mx-auto">
        <h2 class="font-display text-3xl font-bold text-vnn-ink mb-4">Welcome to Valyrian News Network</h2>
        <p class="text-vnn-gray">
          No articles published yet. Check back soon for AI-synthesized, context-rich news analysis.
        </p>
      </div>
    ) : (
      <div class="max-w-7xl mx-auto px-6">
        
        <!-- Country Filter -->
        {activeCountries.length > 0 && (
          <nav class="py-4 animate-fade-in-up relative z-50 flex flex-wrap items-center gap-3" id="country-filter">
            <div class="relative inline-block" id="country-dropdown">
              <button class="country-dropdown-trigger" id="country-trigger" aria-expanded="false" aria-haspopup="listbox">
                <span class="country-dropdown-label">Filter by Country</span>
                <svg class="country-dropdown-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              
              <div class="country-dropdown-panel" id="country-panel" role="listbox" aria-label="Filter articles by country">
                <div class="country-dropdown-search-wrap">
                  <input 
                    type="text" 
                    class="country-dropdown-search" 
                    id="country-search" 
                    placeholder="Search countries…"
                    autocomplete="off"
                  />
                </div>
                <div class="country-dropdown-list" id="country-list">
                  <button class="country-dropdown-item active" data-country="all" role="option" aria-selected="true">
                    <span class="country-dropdown-item-name">All Countries</span>
                    <span class="country-dropdown-item-count">{sortedPosts.length}</span>
                  </button>
                  {activeCountries.map(([country, count]) => (
                    <button class="country-dropdown-item" data-country={country} role="option" aria-selected="false">
                      <span class="country-dropdown-item-name">{country}</span>
                      <span class="country-dropdown-item-count">{count}</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>

            <div class="relative inline-block" id="date-dropdown">
              <button class="country-dropdown-trigger" id="date-trigger" aria-expanded="false">
                <span class="country-dropdown-label" id="date-label">Filter by Date</span>
                <svg class="country-dropdown-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              
              <div class="cal-panel" id="date-panel">
                <div class="cal-header">
                  <button class="cal-nav" id="cal-prev" aria-label="Previous month">‹</button>
                  <span class="cal-month-label" id="cal-month-label"></span>
                  <button class="cal-nav" id="cal-next" aria-label="Next month">›</button>
                </div>
                <div class="cal-weekdays">
                  <span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span><span>Su</span>
                </div>
                <div class="cal-grid" id="cal-grid"></div>
                <button class="cal-today-btn" id="cal-today">Show all dates</button>
              </div>
            </div>

            <script is:inline define:vars={{ articleDateCounts }}>
              window.__articleDateCounts = articleDateCounts;
            </script>

            <button class="country-clear-btn" id="filter-clear" style="display: none;">
              ✕ Clear filters
            </button>
          </nav>
        )}
        
        <!-- Hero Section: Featured + Secondary -->
        <section class="py-8 animate-fade-in-up" id="hero-section">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 items-start">
            
            <!-- Featured Story (left, dominant) -->
            {featuredPost && (
              <div class="lg:col-span-6 lg:pr-10 pb-6 lg:pb-0 filterable-article" data-countries={getCountries(featuredPost.data.tags).join(',')} data-date={formatDateISO(featuredPost.data.date)}>
                <ArticleCard
                  title={featuredPost.data.title}
                  slug={featuredPost.data.slug}
                  date={featuredPost.data.date}
                  meta_description={featuredPost.data.meta_description}
                  categories={featuredPost.data.categories}
                  read_time_minutes={featuredPost.data.read_time_minutes}
                  featured={true}
                />
              </div>
            )}
            
            <!-- Secondary Stories (right column, stacked) -->
            {secondaryPosts.length > 0 && (
              <div class="lg:col-span-6 lg:pl-10 lg:border-l border-vnn-rule flex flex-col">
                {secondaryPosts.map((post, i) => (
                  <div class={`animate-fade-in-up stagger-${i + 1} ${i > 0 ? 'pt-5 mt-5 hairline-top' : ''} filterable-article`} data-countries={getCountries(post.data.tags).join(',')} data-date={formatDateISO(post.data.date)}>
                    <ArticleCard
                      title={post.data.title}
                      slug={post.data.slug}
                      date={post.data.date}
                      meta_description={post.data.meta_description}
                      categories={post.data.categories}
                      read_time_minutes={post.data.read_time_minutes}
                      compact={true}
                      showDate={false}
                    />
                  </div>
                ))}
              </div>
            )}
          </div>
        </section>

        <!-- Date-Grouped Sections (default view, excludes hero articles) -->
        <div id="default-date-groups">
          {remainingDateGroups.map(([dateLabel, posts], groupIndex) => (
            <section class={`date-group animate-fade-in-up stagger-${Math.min(groupIndex + 2, 6)}`}>
              <div class="flex items-center gap-6 py-4 mt-4 date-group-header">
                <div class="h-px bg-vnn-rule flex-1"></div>
                <h2 class="edition-date shrink-0 m-0">{dateLabel}</h2>
                <div class="h-px bg-vnn-rule flex-1"></div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-8 py-8">
                {posts.map((post: typeof remainingPosts[0]) => (
                  <div class="hairline-top pt-6 filterable-article" data-countries={getCountries(post.data.tags).join(',')} data-date={formatDateISO(post.data.date)}>
                    <ArticleCard
                      title={post.data.title}
                      slug={post.data.slug}
                      date={post.data.date}
                      meta_description={post.data.meta_description}
                      categories={post.data.categories}
                      read_time_minutes={post.data.read_time_minutes}
                      showDate={false}
                    />
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>

        <!-- Date-Grouped Sections (filtered view, includes ALL articles) -->
        <div id="filtered-date-groups" style="display: none;">
          {allDateGroups.map(([dateLabel, posts], groupIndex) => (
            <section class={`date-group-all animate-fade-in-up stagger-${Math.min(groupIndex + 2, 6)}`}>
              <div class="flex items-center gap-6 py-4 mt-4 date-group-header">
                <div class="h-px bg-vnn-rule flex-1"></div>
                <h2 class="edition-date shrink-0 m-0">{dateLabel}</h2>
                <div class="h-px bg-vnn-rule flex-1"></div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-8 py-8">
                {posts.map((post: typeof sortedPosts[0]) => (
                  <div class="hairline-top pt-6 filterable-article-all" data-countries={getCountries(post.data.tags).join(',')} data-date={formatDateISO(post.data.date)}>
                    <ArticleCard
                      title={post.data.title}
                      slug={post.data.slug}
                      date={post.data.date}
                      meta_description={post.data.meta_description}
                      categories={post.data.categories}
                      read_time_minutes={post.data.read_time_minutes}
                      showDate={false}
                    />
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
        
        <!-- Support Banner -->
        <section class="my-12 hairline-top py-10">
          <div class="max-w-3xl mx-auto text-center">
            <p class="font-mono text-xs tracking-[0.2em] uppercase text-vnn-muted mb-3">Support Independent AI Journalism</p>
            <p class="font-display text-2xl md:text-3xl font-bold text-vnn-ink leading-snug mb-4">
              Help us keep VNN free and transparent
            </p>
            <p class="text-vnn-gray max-w-xl mx-auto mb-6">
              VNN is funded by readers, not advertisers. Your support helps us maintain 
              independent, transparent, AI-synthesized news coverage for everyone.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <a 
                href="https://patreon.com/ValyrianTech" 
                target="_blank"
                rel="noopener noreferrer"
                class="support-btn"
              >
                Support on Patreon
              </a>
              <a 
                href={withBase('/about')} 
                class="inline-block font-mono text-xs uppercase tracking-widest font-semibold text-vnn-vermillion hover:text-vnn-ink transition-colors border-b-2 border-vnn-vermillion hover:border-vnn-ink pb-1"
              >
                Learn How VNN Works
              </a>
            </div>
          </div>
        </section>
        
      </div>
    )}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Elements
      const heroSection = document.getElementById('hero-section');
      const defaultDateGroupsWrap = document.getElementById('default-date-groups') as HTMLElement | null;
      const filteredDateGroupsWrap = document.getElementById('filtered-date-groups') as HTMLElement | null;
      const clearBtn = document.getElementById('filter-clear') as HTMLButtonElement | null;

      // Country dropdown elements
      const countryTrigger = document.getElementById('country-trigger') as HTMLButtonElement | null;
      const countryPanel = document.getElementById('country-panel') as HTMLElement | null;
      const countrySearch = document.getElementById('country-search') as HTMLInputElement | null;
      const countryList = document.getElementById('country-list') as HTMLElement | null;
      const countryLabel = countryTrigger?.querySelector('.country-dropdown-label') as HTMLElement | null;

      // Calendar elements
      const dateTrigger = document.getElementById('date-trigger') as HTMLButtonElement | null;
      const datePanel = document.getElementById('date-panel') as HTMLElement | null;
      const dateLabel = document.getElementById('date-label') as HTMLElement | null;
      const calGrid = document.getElementById('cal-grid') as HTMLElement | null;
      const calMonthLabel = document.getElementById('cal-month-label') as HTMLElement | null;
      const calPrev = document.getElementById('cal-prev') as HTMLButtonElement | null;
      const calNext = document.getElementById('cal-next') as HTMLButtonElement | null;
      const calToday = document.getElementById('cal-today') as HTMLButtonElement | null;

      if (!countryTrigger || !countryPanel || !countrySearch || !countryList || !countryLabel ||
          !dateTrigger || !datePanel || !dateLabel || !calGrid || !calMonthLabel ||
          !calPrev || !calNext || !calToday || !clearBtn ||
          !defaultDateGroupsWrap || !filteredDateGroupsWrap) return;

      // Article date counts from server
      const articleDateCounts: Record<string, number> = (window as any).__articleDateCounts || {};

      // State
      let activeCountry = 'all';
      let activeDate = 'all';
      let openPanelEl: HTMLElement | null = null;
      let calYear: number;
      let calMonth: number; // 0-indexed

      // Initialize calendar to the most recent article date, or today
      const dateKeys = Object.keys(articleDateCounts).sort().reverse();
      if (dateKeys.length > 0) {
        const [y, m] = dateKeys[0].split('-').map(Number);
        calYear = y;
        calMonth = m - 1;
      } else {
        const now = new Date();
        calYear = now.getFullYear();
        calMonth = now.getMonth();
      }

      // ── Panel helpers ──
      function openCountryDropdown() {
        closeAllPanels();
        openPanelEl = countryPanel;
        countryPanel!.classList.add('open');
        countryTrigger!.setAttribute('aria-expanded', 'true');
        countrySearch!.value = '';
        filterCountryList('');
        setTimeout(() => countrySearch!.focus(), 50);
      }

      function openCalendar() {
        closeAllPanels();
        openPanelEl = datePanel;
        datePanel!.classList.add('open');
        dateTrigger!.setAttribute('aria-expanded', 'true');
        renderCalendar();
      }

      function closeAllPanels() {
        openPanelEl = null;
        countryPanel!.classList.remove('open');
        datePanel!.classList.remove('open');
        countryTrigger!.setAttribute('aria-expanded', 'false');
        dateTrigger!.setAttribute('aria-expanded', 'false');
      }

      // ── Country search ──
      function filterCountryList(query: string) {
        const items = countryList!.querySelectorAll<HTMLElement>('.country-dropdown-item');
        const q = query.toLowerCase().trim();
        items.forEach(item => {
          if (item.dataset.country === 'all') { item.style.display = ''; return; }
          const name = item.querySelector('.country-dropdown-item-name')?.textContent?.toLowerCase() || '';
          item.style.display = name.includes(q) ? '' : 'none';
        });
      }

      // ── Calendar rendering ──
      function pad(n: number): string { return n < 10 ? '0' + n : '' + n; }

      function renderCalendar() {
        const monthNames = ['January','February','March','April','May','June',
                            'July','August','September','October','November','December'];
        calMonthLabel!.textContent = `${monthNames[calMonth]} ${calYear}`;

        // First day of month (0=Sun, convert to Mon=0)
        const firstDay = new Date(calYear, calMonth, 1).getDay();
        const startOffset = (firstDay + 6) % 7; // Monday-based
        const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();

        let html = '';

        // Empty cells for offset
        for (let i = 0; i < startOffset; i++) {
          html += '<span class="cal-day cal-day-empty"></span>';
        }

        // Day cells
        for (let d = 1; d <= daysInMonth; d++) {
          const iso = `${calYear}-${pad(calMonth + 1)}-${pad(d)}`;
          const count = articleDateCounts[iso] || 0;
          const hasArticles = count > 0;
          const isSelected = activeDate === iso;

          let cls = 'cal-day';
          if (!hasArticles) cls += ' cal-day-disabled';
          if (hasArticles) cls += ' cal-day-has-articles';
          if (isSelected) cls += ' cal-day-selected';

          html += `<button class="${cls}" data-date="${iso}" ${!hasArticles ? 'disabled' : ''}>`;
          html += `<span class="cal-day-num">${d}</span>`;
          if (hasArticles) {
            html += `<span class="cal-day-dot"></span>`;
          }
          html += `</button>`;
        }

        calGrid!.innerHTML = html;
      }

      // ── Helper: filter articles within a container ──
      function filterArticlesIn(container: HTMLElement, articleClass: string, groupClass: string) {
        const arts = container.querySelectorAll<HTMLElement>(`.${articleClass}`);
        arts.forEach(a => {
          const matchesCountry = activeCountry === 'all' ||
            (a.dataset.countries || '').split(',').includes(activeCountry);
          const matchesDate = activeDate === 'all' ||
            a.dataset.date === activeDate;
          if (matchesCountry && matchesDate) {
            a.style.display = '';
            a.classList.remove('filtered-hidden');
          } else {
            a.style.display = 'none';
            a.classList.add('filtered-hidden');
          }
        });
        const groups = container.querySelectorAll<HTMLElement>(`.${groupClass}`);
        groups.forEach(group => {
          const visible = group.querySelectorAll(`.${articleClass}:not(.filtered-hidden)`);
          group.style.display = visible.length === 0 ? 'none' : '';
        });
      }

      // ── Unified filter logic ──
      function applyFilters() {
        const isDateFiltered = activeDate !== 'all';

        // Swap between default view (hero + remaining) and filtered view (all articles in grid)
        if (isDateFiltered) {
          heroSection!.style.display = 'none';
          defaultDateGroupsWrap!.style.display = 'none';
          filteredDateGroupsWrap!.style.display = '';
          filterArticlesIn(filteredDateGroupsWrap!, 'filterable-article-all', 'date-group-all');
        } else {
          filteredDateGroupsWrap!.style.display = 'none';
          defaultDateGroupsWrap!.style.display = '';
          heroSection!.style.display = '';

          // Filter hero articles
          const heroArts = heroSection!.querySelectorAll<HTMLElement>('.filterable-article');
          heroArts.forEach(a => {
            const matchesCountry = activeCountry === 'all' ||
              (a.dataset.countries || '').split(',').includes(activeCountry);
            if (matchesCountry) {
              a.style.display = '';
              a.classList.remove('filtered-hidden');
            } else {
              a.style.display = 'none';
              a.classList.add('filtered-hidden');
            }
          });
          const visibleHero = heroSection!.querySelectorAll('.filterable-article:not(.filtered-hidden)');
          heroSection!.style.display = visibleHero.length === 0 ? 'none' : '';

          // Filter default date groups
          filterArticlesIn(defaultDateGroupsWrap!, 'filterable-article', 'date-group');
        }

        clearBtn!.style.display = (activeCountry !== 'all' || activeDate !== 'all') ? '' : 'none';

        const url = new URL(window.location.href);
        activeCountry === 'all' ? url.searchParams.delete('country') : url.searchParams.set('country', activeCountry);
        activeDate === 'all' ? url.searchParams.delete('date') : url.searchParams.set('date', activeDate);
        window.history.replaceState({}, '', url.toString());
      }

      // ── Select handlers ──
      function selectCountry(country: string) {
        activeCountry = country;
        const items = countryList!.querySelectorAll<HTMLElement>('.country-dropdown-item');
        items.forEach(item => {
          const isActive = item.dataset.country === country;
          item.classList.toggle('active', isActive);
          item.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        if (country === 'all') {
          countryLabel!.textContent = 'Filter by Country';
          countryTrigger!.classList.remove('has-selection');
        } else {
          countryLabel!.textContent = country;
          countryTrigger!.classList.add('has-selection');
        }
        closeAllPanels();
        applyFilters();
      }

      function selectDate(dateKey: string) {
        activeDate = dateKey;
        if (dateKey === 'all') {
          dateLabel!.textContent = 'Filter by Date';
          dateTrigger!.classList.remove('has-selection');
        } else {
          const d = new Date(dateKey + 'T12:00:00');
          dateLabel!.textContent = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          dateTrigger!.classList.add('has-selection');
        }
        closeAllPanels();
        applyFilters();
      }

      // ── Event listeners ──

      // Country dropdown
      countryTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        openPanelEl === countryPanel ? closeAllPanels() : openCountryDropdown();
      });
      countrySearch.addEventListener('input', () => filterCountryList(countrySearch.value));
      countrySearch.addEventListener('click', (e) => e.stopPropagation());
      countrySearch.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { closeAllPanels(); countryTrigger.focus(); }
        else if (e.key === 'Enter') {
          const visible = Array.from(countryList.querySelectorAll<HTMLElement>('.country-dropdown-item'))
            .filter(item => item.style.display !== 'none');
          if (visible.length > 0 && visible[0].dataset.country) selectCountry(visible[0].dataset.country);
        }
      });
      countryList.addEventListener('click', (e) => {
        const item = (e.target as HTMLElement).closest<HTMLElement>('.country-dropdown-item');
        if (item?.dataset.country) selectCountry(item.dataset.country);
      });

      // Calendar
      dateTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        openPanelEl === datePanel ? closeAllPanels() : openCalendar();
      });

      calPrev.addEventListener('click', (e) => {
        e.stopPropagation();
        calMonth--;
        if (calMonth < 0) { calMonth = 11; calYear--; }
        renderCalendar();
      });

      calNext.addEventListener('click', (e) => {
        e.stopPropagation();
        calMonth++;
        if (calMonth > 11) { calMonth = 0; calYear++; }
        renderCalendar();
      });

      calGrid.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.cal-day:not(.cal-day-disabled)');
        if (btn?.dataset.date) {
          selectDate(btn.dataset.date);
        }
      });

      calToday.addEventListener('click', (e) => {
        e.stopPropagation();
        selectDate('all');
      });

      // Prevent panel clicks from bubbling
      datePanel.addEventListener('click', (e) => e.stopPropagation());

      // Clear all filters
      clearBtn.addEventListener('click', () => {
        selectCountry('all');
        selectDate('all');
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (openPanelEl && !(e.target as HTMLElement).closest('#country-dropdown') && !(e.target as HTMLElement).closest('#date-dropdown')) {
          closeAllPanels();
        }
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && openPanelEl) closeAllPanels();
      });

      // ── Read URL params on load ──
      const urlParams = new URLSearchParams(window.location.search);
      const urlCountry = urlParams.get('country');
      const urlDate = urlParams.get('date');
      if (urlCountry) {
        const match = Array.from(countryList.querySelectorAll<HTMLElement>('.country-dropdown-item'))
          .find(item => item.dataset.country === urlCountry);
        if (match) selectCountry(urlCountry);
      }
      if (urlDate && articleDateCounts[urlDate]) {
        // Navigate calendar to that month
        const [y, m] = urlDate.split('-').map(Number);
        calYear = y;
        calMonth = m - 1;
        selectDate(urlDate);
      }
    });
  </script>
</BaseLayout>
