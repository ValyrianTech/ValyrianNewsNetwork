---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCountries } from '../utils/countries';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPost = sortedPosts[0];
const secondaryPosts = sortedPosts.slice(1, 4);
const remainingPosts = sortedPosts.slice(4);

// Build country counts from all posts
const countryCounts: Record<string, number> = {};
for (const post of sortedPosts) {
  for (const country of getCountries(post.data.tags)) {
    countryCounts[country] = (countryCounts[country] || 0) + 1;
  }
}
const activeCountries = Object.entries(countryCounts)
  .sort((a, b) => a[0].localeCompare(b[0]));

// Group remaining posts by date
const groupedByDate = remainingPosts.reduce((groups: Record<string, typeof remainingPosts>, post) => {
  const dateKey = post.data.date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
  if (!groups[dateKey]) {
    groups[dateKey] = [];
  }
  groups[dateKey].push(post);
  return groups;
}, {});

const dateGroups = Object.entries(groupedByDate);
---

<BaseLayout title="Home">
  <div class="paper-texture">
    {sortedPosts.length === 0 ? (
      <div class="text-center py-24 max-w-xl mx-auto">
        <h2 class="font-display text-3xl font-bold text-vnn-ink mb-4">Welcome to Valyrian News Network</h2>
        <p class="text-vnn-gray">
          No articles published yet. Check back soon for AI-synthesized, context-rich news analysis.
        </p>
      </div>
    ) : (
      <div class="max-w-7xl mx-auto px-6">
        
        <!-- Country Filter -->
        {activeCountries.length > 0 && (
          <nav class="py-4 animate-fade-in-up relative z-50" id="country-filter">
            <div class="relative inline-block" id="country-dropdown">
              <button class="country-dropdown-trigger" id="country-trigger" aria-expanded="false" aria-haspopup="listbox">
                <span class="country-dropdown-label">Filter by Country</span>
                <svg class="country-dropdown-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              
              <div class="country-dropdown-panel" id="country-panel" role="listbox" aria-label="Filter articles by country">
                <div class="country-dropdown-search-wrap">
                  <input 
                    type="text" 
                    class="country-dropdown-search" 
                    id="country-search" 
                    placeholder="Search countries…"
                    autocomplete="off"
                  />
                </div>
                <div class="country-dropdown-list" id="country-list">
                  <button class="country-dropdown-item active" data-country="all" role="option" aria-selected="true">
                    <span class="country-dropdown-item-name">All Countries</span>
                    <span class="country-dropdown-item-count">{sortedPosts.length}</span>
                  </button>
                  {activeCountries.map(([country, count]) => (
                    <button class="country-dropdown-item" data-country={country} role="option" aria-selected="false">
                      <span class="country-dropdown-item-name">{country}</span>
                      <span class="country-dropdown-item-count">{count}</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>

            <button class="country-clear-btn" id="country-clear" style="display: none;">
              ✕ Clear filter
            </button>
          </nav>
        )}
        
        <!-- Hero Section: Featured + Secondary -->
        <section class="py-8 animate-fade-in-up" id="hero-section">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 items-start">
            
            <!-- Featured Story (left, dominant) -->
            {featuredPost && (
              <div class="lg:col-span-7 lg:pr-10 lg:border-r border-vnn-rule pb-6 lg:pb-0 filterable-article" data-countries={getCountries(featuredPost.data.tags).join(',')}>
                <ArticleCard
                  title={featuredPost.data.title}
                  slug={featuredPost.data.slug}
                  date={featuredPost.data.date}
                  meta_description={featuredPost.data.meta_description}
                  categories={featuredPost.data.categories}
                  read_time_minutes={featuredPost.data.read_time_minutes}
                  featured={true}
                />
              </div>
            )}
            
            <!-- Secondary Stories (right column, stacked) -->
            {secondaryPosts.length > 0 && (
              <div class="lg:col-span-5 lg:pl-10 flex flex-col">
                {secondaryPosts.map((post, i) => (
                  <div class={`animate-fade-in-up stagger-${i + 1} ${i > 0 ? 'pt-8 mt-8 hairline-top' : ''} filterable-article`} data-countries={getCountries(post.data.tags).join(',')}>
                    <ArticleCard
                      title={post.data.title}
                      slug={post.data.slug}
                      date={post.data.date}
                      meta_description={post.data.meta_description}
                      categories={post.data.categories}
                      read_time_minutes={post.data.read_time_minutes}
                      compact={true}
                      showDate={false}
                    />
                  </div>
                ))}
              </div>
            )}
          </div>
        </section>

        <!-- Date-Grouped Article Sections -->
        {dateGroups.map(([dateLabel, posts], groupIndex) => (
          <section class={`date-group animate-fade-in-up stagger-${Math.min(groupIndex + 2, 6)}`}>
            <!-- Edition Date Header -->
            <div class="flex items-center gap-6 py-4 mt-4 date-group-header">
              <div class="h-px bg-vnn-rule flex-1"></div>
              <h2 class="edition-date shrink-0 m-0">{dateLabel}</h2>
              <div class="h-px bg-vnn-rule flex-1"></div>
            </div>
            
            <!-- Articles Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-8 py-8">
              {posts.map((post: typeof remainingPosts[0]) => (
                <div class="hairline-top pt-6 filterable-article" data-countries={getCountries(post.data.tags).join(',')}>
                  <ArticleCard
                    title={post.data.title}
                    slug={post.data.slug}
                    date={post.data.date}
                    meta_description={post.data.meta_description}
                    categories={post.data.categories}
                    read_time_minutes={post.data.read_time_minutes}
                    showDate={false}
                  />
                </div>
              ))}
            </div>
          </section>
        ))}
        
        <!-- About / Methodology Banner -->
        <section class="my-12 hairline-top hairline-bottom py-10">
          <div class="max-w-3xl mx-auto text-center">
            <p class="font-mono text-xs tracking-[0.2em] uppercase text-vnn-muted mb-3">About Our Methodology</p>
            <p class="font-display text-2xl md:text-3xl font-bold text-vnn-ink leading-snug mb-4">
              AI-synthesized news with full transparency
            </p>
            <p class="text-vnn-gray max-w-xl mx-auto mb-6">
              Every article is sourced, analyzed, and composed by automated systems. 
              We believe in radical transparency about our process.
            </p>
            <a 
              href="/about" 
              class="inline-block font-mono text-xs uppercase tracking-widest font-semibold text-vnn-vermillion hover:text-vnn-ink transition-colors border-b-2 border-vnn-vermillion hover:border-vnn-ink pb-1"
            >
              Learn How VNN Works
            </a>
          </div>
        </section>
        
      </div>
    )}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const trigger = document.getElementById('country-trigger') as HTMLButtonElement | null;
      const panel = document.getElementById('country-panel') as HTMLElement | null;
      const search = document.getElementById('country-search') as HTMLInputElement | null;
      const list = document.getElementById('country-list') as HTMLElement | null;
      const clearBtn = document.getElementById('country-clear') as HTMLButtonElement | null;
      const label = trigger?.querySelector('.country-dropdown-label') as HTMLElement | null;
      const articles = document.querySelectorAll<HTMLElement>('.filterable-article');
      const dateGroups = document.querySelectorAll<HTMLElement>('.date-group');
      const heroSection = document.getElementById('hero-section');
      
      if (!trigger || !panel || !search || !list || !clearBtn || !label) return;

      let isOpen = false;
      let activeCountry = 'all';

      function openDropdown() {
        isOpen = true;
        panel!.classList.add('open');
        trigger!.setAttribute('aria-expanded', 'true');
        search!.value = '';
        filterList('');
        setTimeout(() => search!.focus(), 50);
      }

      function closeDropdown() {
        isOpen = false;
        panel!.classList.remove('open');
        trigger!.setAttribute('aria-expanded', 'false');
      }

      function filterList(query: string) {
        const items = list!.querySelectorAll<HTMLElement>('.country-dropdown-item');
        const q = query.toLowerCase().trim();
        items.forEach(item => {
          if (item.dataset.country === 'all') {
            item.style.display = '';
            return;
          }
          const name = item.querySelector('.country-dropdown-item-name')?.textContent?.toLowerCase() || '';
          item.style.display = name.includes(q) ? '' : 'none';
        });
      }

      function selectCountry(country: string) {
        activeCountry = country;
        
        // Update active item styling
        const items = list!.querySelectorAll<HTMLElement>('.country-dropdown-item');
        items.forEach(item => {
          const isActive = item.dataset.country === country;
          item.classList.toggle('active', isActive);
          item.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        // Update trigger label
        if (country === 'all') {
          label!.textContent = 'Filter by Country';
          trigger!.classList.remove('has-selection');
          clearBtn!.style.display = 'none';
        } else {
          label!.textContent = country;
          trigger!.classList.add('has-selection');
          clearBtn!.style.display = '';
        }

        // Filter articles
        if (country === 'all') {
          articles.forEach(a => {
            a.style.display = '';
            a.classList.remove('filtered-hidden');
          });
          dateGroups.forEach(g => g.style.display = '');
          if (heroSection) heroSection.style.display = '';
        } else {
          articles.forEach(a => {
            const countries = (a.dataset.countries || '').split(',');
            if (countries.includes(country)) {
              a.style.display = '';
              a.classList.remove('filtered-hidden');
            } else {
              a.style.display = 'none';
              a.classList.add('filtered-hidden');
            }
          });

          dateGroups.forEach(group => {
            const visible = group.querySelectorAll('.filterable-article:not(.filtered-hidden)');
            group.style.display = visible.length === 0 ? 'none' : '';
          });

          if (heroSection) {
            const visibleHero = heroSection.querySelectorAll('.filterable-article:not(.filtered-hidden)');
            heroSection.style.display = visibleHero.length === 0 ? 'none' : '';
          }
        }

        closeDropdown();
      }

      // Toggle dropdown
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen ? closeDropdown() : openDropdown();
      });

      // Search input
      search.addEventListener('input', () => filterList(search.value));
      search.addEventListener('click', (e) => e.stopPropagation());

      // Keyboard navigation
      search.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeDropdown();
          trigger.focus();
        } else if (e.key === 'Enter') {
          const visibleItems = Array.from(list.querySelectorAll<HTMLElement>('.country-dropdown-item'))
            .filter(item => item.style.display !== 'none');
          if (visibleItems.length > 0) {
            const country = visibleItems[0].dataset.country;
            if (country) selectCountry(country);
          }
        }
      });

      // Item click
      list.addEventListener('click', (e) => {
        const item = (e.target as HTMLElement).closest<HTMLElement>('.country-dropdown-item');
        if (item?.dataset.country) {
          selectCountry(item.dataset.country);
        }
      });

      // Clear button
      clearBtn.addEventListener('click', () => selectCountry('all'));

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (isOpen && !(e.target as HTMLElement).closest('#country-dropdown')) {
          closeDropdown();
        }
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) closeDropdown();
      });
    });
  </script>
</BaseLayout>
