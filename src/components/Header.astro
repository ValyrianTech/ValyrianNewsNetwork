---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
];
---

<header class="border-b border-gray-200 bg-white">
  <div class="max-w-6xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="no-underline hover:no-underline">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-vnn-blue rounded flex items-center justify-center">
            <span class="text-white font-bold text-lg font-serif">V</span>
          </div>
          <div>
            <h1 class="text-xl font-bold text-vnn-charcoal m-0 leading-tight">Valyrian News Network</h1>
            <p class="text-xs text-vnn-gray m-0">Understanding, Automated.</p>
          </div>
        </div>
      </a>
      
      <nav class="flex items-center gap-6">
        {navLinks.map(link => (
          <a 
            href={link.href} 
            class="text-vnn-charcoal no-underline hover:text-vnn-blue transition-colors font-medium"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
