---
const currentYear = new Date().getFullYear();
---

<footer class="bg-vnn-ink text-white mt-0">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      
      <!-- Brand -->
      <div class="md:col-span-5">
        <h3 class="font-display text-2xl font-bold text-white mb-3 leading-tight">
          Valyrian News Network
        </h3>
        <p class="text-sm text-gray-400 leading-relaxed max-w-sm">
          AI-synthesized, context-rich news analysis with full transparency 
          about our automated methodology. A project of Valyrian Tech, 
          powered by the SERENDIPITY AGI framework.
        </p>
      </div>
      
      <!-- Navigation -->
      <div class="md:col-span-3 md:col-start-7">
        <h4 class="font-mono text-xs uppercase tracking-[0.15em] text-gray-500 mb-5">Navigate</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-gray-300 hover:text-vnn-vermillion no-underline transition-colors text-sm">Home</a></li>
          <li><a href="/about" class="text-gray-300 hover:text-vnn-vermillion no-underline transition-colors text-sm">Our Methodology</a></li>
          <li><a href="/rss.xml" class="text-gray-300 hover:text-vnn-vermillion no-underline transition-colors text-sm">RSS Feed</a></li>
        </ul>
      </div>
      
      <!-- Info -->
      <div class="md:col-span-3">
        <h4 class="font-mono text-xs uppercase tracking-[0.15em] text-gray-500 mb-5">Transparency</h4>
        <p class="text-sm text-gray-400 leading-relaxed">
          Every article is synthesized by AI systems with cited sources. 
          <a href="/about" class="text-vnn-vermillion hover:text-white no-underline transition-colors">Learn how it works →</a>
        </p>
      </div>
    </div>
    
    <!-- Bottom bar -->
    <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-xs font-mono tracking-wide">
        &copy; {currentYear} Valyrian Tech. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="text-gray-500 hover:text-vnn-vermillion no-underline transition-colors text-xs font-mono tracking-wide">Privacy</a>
        <a href="/terms" class="text-gray-500 hover:text-vnn-vermillion no-underline transition-colors text-xs font-mono tracking-wide">Terms</a>
      </div>
      <p class="text-gray-600 text-xs font-mono tracking-wide">
        Understanding, Automated.
      </p>
    </div>
  </div>
</footer>
