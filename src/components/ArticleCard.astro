---
import { getPostUrl } from '../utils/urls';

interface Props {
  title: string;
  slug: string;
  date: Date;
  meta_description: string;
  categories: string[];
  read_time_minutes: number;
  featured?: boolean;
  compact?: boolean;
  showDate?: boolean;
}

const { title, slug, date, meta_description, categories, read_time_minutes, featured = false, compact = false, showDate = true } = Astro.props;

const postUrl = getPostUrl(slug, date);
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

{featured ? (
  <article class="article-card group">
    <div class="flex flex-wrap gap-3 mb-3">
      {categories.map(category => (
        <span class="category-pill">{category}</span>
      ))}
    </div>
    
    <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-black mb-4 leading-[1.1] tracking-tight">
      <a href={postUrl} class="text-vnn-ink no-underline group-hover:text-vnn-vermillion transition-colors duration-300">
        {title}
      </a>
    </h2>
    
    <p class="text-vnn-gray text-lg leading-relaxed mb-4 font-body">
      {meta_description}
    </p>
    
    {showDate && (
      <div class="flex items-center gap-3 edition-date">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-vnn-rule">—</span>
        <span>{read_time_minutes} min read</span>
      </div>
    )}
  </article>
) : compact ? (
  <article class="article-card group">
    <div class="flex flex-wrap gap-2 mb-1.5">
      {categories.map(category => (
        <span class="category-pill" style="font-size: 0.6rem;">{category}</span>
      ))}
    </div>
    
    <h3 class="font-display text-lg font-bold mb-1.5 leading-snug">
      <a href={postUrl} class="text-vnn-ink no-underline group-hover:text-vnn-vermillion transition-colors duration-300">
        {title}
      </a>
    </h3>
    
    <p class="text-vnn-gray text-sm leading-relaxed mb-2">
      {meta_description}
    </p>
    
    {showDate && (
      <div class="edition-date" style="font-size: 0.6rem;">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-vnn-rule mx-1.5">—</span>
        <span>{read_time_minutes} min read</span>
      </div>
    )}
  </article>
) : (
  <article class="article-card group">
    <div class="flex flex-wrap gap-2 mb-2">
      {categories.map(category => (
        <span class="category-pill">{category}</span>
      ))}
    </div>
    
    <h3 class="font-display text-xl md:text-2xl font-bold mb-2 leading-tight">
      <a href={postUrl} class="text-vnn-ink no-underline group-hover:text-vnn-vermillion transition-colors duration-300">
        {title}
      </a>
    </h3>
    
    <p class="text-vnn-gray leading-relaxed mb-2.5">
      {meta_description}
    </p>
    
    {showDate && (
      <div class="edition-date">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-vnn-rule mx-2">—</span>
        <span>{read_time_minutes} min read</span>
      </div>
    )}
  </article>
)}
